rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        request.auth.token.email == "augustocross87@gmail.com";
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdminRole() {
      return isSignedIn() && getUserData().role == "admin";
    }

    function isBrandAdmin(brandId) {
      return isSignedIn() &&
        getUserData().role == "client" &&
        getUserData().brandId == brandId &&
        getUserData().active == true;
    }

    function canManageBrand(brandId) {
      return isSuperAdmin() || isAdminRole() || isBrandAdmin(brandId);
    }

    // Campos privilegiados que apenas super_admin/admin podem alterar.
    // Um usuário não pode escalar o próprio role mesmo com acesso de escrita ao doc.
    function selfUpdateAllowed() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'brandId', 'active', 'createdBy', 'uid']);
    }

    // ─── Users ─────────────────────────────────────────────────────────────────
    // Super admin gerencia tudo. Usuário lê/atualiza campos não-privilegiados do próprio perfil.

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin() || isAdminRole());
      allow create: if isSuperAdmin() || isAdminRole();
      allow update: if (isSignedIn() && request.auth.uid == uid && selfUpdateAllowed())
                    || isSuperAdmin() || isAdminRole();
      allow delete: if isSuperAdmin() || isAdminRole();
    }

    // ─── Brands ────────────────────────────────────────────────────────────────
    // Leitura pública. Criação/edição: super admin.

    match /brands/{brandId} {
      allow read: if true;
      allow create: if isSuperAdmin() || isAdminRole();
      allow update: if isSuperAdmin() || isAdminRole() || isBrandAdmin(brandId);
      allow delete: if isSuperAdmin() || isAdminRole();
    }

    // ─── Products ──────────────────────────────────────────────────────────────
    // Leitura pública. Escrita: admin ou dono da marca.

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        (isSuperAdmin() || isAdminRole() ||
          (getUserData().role == "client" && getUserData().brandId == request.resource.data.brandId));
      allow update: if isSignedIn() &&
        (isSuperAdmin() || isAdminRole() ||
          isBrandAdmin(resource.data.brandId));
      allow delete: if isSuperAdmin() || isAdminRole() ||
        (isSignedIn() && isBrandAdmin(resource.data.brandId));
    }

    // ─── Categories ────────────────────────────────────────────────────────────

    match /categories/{catId} {
      allow read: if true;
      allow write: if isSignedIn() &&
        (isSuperAdmin() || isAdminRole() ||
          (getUserData().role == "client" &&
            (resource == null || getUserData().brandId == resource.data.brandId)));
    }

    // ─── Banners ───────────────────────────────────────────────────────────────

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isSignedIn() &&
        (isSuperAdmin() || isAdminRole() ||
          (getUserData().role == "client" &&
            (resource == null || getUserData().brandId == resource.data.brandId)));
    }

    // ─── Config (store settings, notifications) ────────────────────────────────

    match /config/{configId} {
      allow read: if true;
      allow write: if isSignedIn() && (isSuperAdmin() || isAdminRole());
    }

    // ─── Vendors ───────────────────────────────────────────────────────────────

    match /vendors/{vendorId} {
      allow read, write: if isSuperAdmin() || isAdminRole();
    }

    // ─── Orders ────────────────────────────────────────────────────────────────
    // Qualquer um pode criar pedido (catálogo público). Admin/dono lê e atualiza.

    match /orders/{orderId} {
      allow create: if true;
      allow read: if isSignedIn() &&
        (isSuperAdmin() || isAdminRole() ||
          (resource != null && isBrandAdmin(resource.data.brandId)));
      allow update, delete: if isSuperAdmin() || isAdminRole() ||
        (isSignedIn() && resource != null && isBrandAdmin(resource.data.brandId));
    }
  }
}
